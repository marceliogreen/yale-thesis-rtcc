# FBI Crime Data Explorer API
# Get key at: https://api.data.gov/signup/
FBI_API_KEY=your_fbi_api_key_here

# BJS NIBRS API (optional)
# BJS_API_KEY=your_bjs_api_key_here

# ICPSR Researcher Passport
# ICPSR_API_KEY=your_icpsr_token_here
# ICPSR_EMAIL=your_email_here

# Data paths
# UCR_ARRESTS_PATH=/path/to/ICPSR_39063
# NIBRS_CLEARANCE_PATH=/path/to/ICPSR_39270

# Scraping configuration
SCRAPER_USER_AGENT="RTCC_Thesis_Research/1.0 (marcelo.green@yale.edu)"
SCRAPER_DELAY_MIN=1
SCRAPER_CACHE_TTL=86400
